{
  "name": "ultimate-pokemon-card-tracker",
  "private": true,
  "scripts": {
    "lint": "eslint public/*.js",
    "test:site": "npm run lint && node tests/site/ci_checks.mjs",
    "test:coverage": "c8 --reporter=lcov node --test tests/unit/*.test.mjs",
    "test:python": "python -m unittest discover -s tests/python -v",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "c8": "12.0.0",
    "eslint": "10.7.0"
  }
}
