{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions updates"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "SheetJS (xlsx) version pinned in the cdnjs <script> tag in tracker.html - not seen by any default manager since it's a raw URL, not a package.json/lockfile",
      "managerFilePatterns": [
        "/^tracker\\.html$/"
      ],
      "matchStrings": [
        "cdnjs\\.cloudflare\\.com/ajax/libs/xlsx/(?<currentValue>[^/\"]+)/xlsx\\.full\\.min\\.js"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "xlsx"
    }
  ]
}